NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8080

DB_CLIENT=postgres
DATABASE_URL=postgres://vehiamb:vehiamb_dev@localhost:5433/vehiamb

AUTH_SECRET=vehiamb-dev-secret
AUTH_TOKEN_HOURS=12

SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@vehiamb.local
SEED_ADMIN_PASSWORD=Admin123*
SEED_ADMIN_ROLE=Administrador

# Importacion de gastos vehiculares (Excel CARGUES_BODEGA).
# EXCEL_FILE_PATH es la ruta que ve el proceso Node, NO necesariamente la
# ruta UNC original:
#
# - Servidor de PRODUCCION (Windows, Node corriendo nativo sin Docker): usar
#   la ruta de red tal cual, ej. "T:\CARGUES BODEGA.xlsm" o
#   "\\192.168.9.21\DESPACHOS\CARGUES BODEGA.xlsm". fs.copyFile la resuelve
#   sin nada adicional, siempre que la cuenta que corre el proceso tenga
#   permiso de lectura sobre el share.
# - Solo para DESARROLLO LOCAL via docker-compose (ver docker-compose.yml en
#   la raiz): el contenedor es Linux y no resuelve UNC directamente, asi que
#   ahi esta variable apunta a la ruta YA MONTADA dentro del contenedor,
#   normalmente "/mnt/despachos/CARGUES BODEGA.xlsm" (ver .env.example de la
#   raiz y la variable DESPACHOS_HOST_PATH que controla ese mount). El
#   docker-compose de este repo es solo para desarrollo: la produccion no
#   corre en Docker.
EXCEL_FILE_PATH=T:\CARGUES BODEGA.xlsm
EXCEL_RETRY_ATTEMPTS=3
EXCEL_RETRY_DELAY=5000
# Job diario que finaliza el periodo de "ayer" (red de seguridad)
IMPORT_SCHEDULE=0 2 * * *
IMPORT_TIMEZONE=America/Bogota
# Job cada 4 horas que sincroniza el periodo de "hoy" (cambios del mismo dia)
GASTOS_SYNC_SCHEDULE=0 */4 * * *

# Importacion de configuracion de vehiculos (repuestos sugeridos para cambio
# de aceite + equivalencias). Mismo tipo de ruta que EXCEL_FILE_PATH (ver
# nota arriba: UNC/unidad de red en produccion, /mnt/... solo en Docker).
# Bootstrap idempotente (nunca pisa configuracion manual), se sincroniza una
# vez al dia porque este archivo cambia con poca frecuencia.
CONFIG_EXCEL_FILE_PATH=\\192.168.9.21\automotores\CAMBIO DE ACEITE VEHICULOS (1).xlsx
CONFIG_SYNC_SCHEDULE=0 4 * * *

# Importacion de stock/saldo de inventario. Mismo tipo de ruta que las
# variables de arriba (UNC/unidad de red en produccion, /mnt/... solo en
# Docker) -- en produccion apunta al mismo archivo que CONFIG_EXCEL_FILE_PATH,
# porque el saldo vive en su propia hoja ("SALDO") dentro de ese mismo libro.
STOCK_EXCEL_FILE_PATH=\\192.168.9.21\automotores\CAMBIO DE ACEITE VEHICULOS (1).xlsx
STOCK_IMPORT_SCHEDULE=0 3 * * *

# Canal de email para notificaciones (ver notificaciones-email.channel.js).
# Si SMTP_HOST se deja vacio, el canal queda inactivo (no rompe nada en
# dev/local sin SMTP configurado). Con un proveedor tipo Gmail Workspace,
# Resend, SendGrid SMTP, etc., basta con completar estos datos.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VehiAmb <notificaciones@vehiamb.local>
# Prioridad minima que dispara email: critica | alta | media | informativa.
# Por defecto solo critica y alta llegan a correo.
EMAIL_ALERT_PRIORIDAD_MINIMA=alta
# Base usada para armar el enlace "Ver en VehiAmb" dentro del correo.
APP_BASE_URL=http://localhost:8080
